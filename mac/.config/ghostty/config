shell-integration = zsh
theme = lackluster

cursor-style = bar
cursor-style-blink = false
font-family = Berkeley Mono
font-size = 24
macos-icon = blueprint
macos-option-as-alt = true
shell-integration-features = "no-cursor"

copy-on-select = true
window-padding-x = 8
window-padding-y = 8

keybind = global:unconsumed:ctrl+shift+r=reload_config
