shell-integration = zsh
theme = lackluster

cursor-style = bar
cursor-style-blink = false
font-family = Berkeley Mono Regular
font-size = 14
shell-integration-features = "no-cursor"

copy-on-select = true
window-padding-x = 8
window-padding-y = 8

keybind = global:unconsumed:ctrl+shift+r=reload_config
